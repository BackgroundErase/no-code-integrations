{
    "name": "@backgrounderase/n8n-nodes-backgrounderase",
    "version": "0.1.7",
    "description": "n8n community node for removing image backgrounds with BackgroundErase.",
    "license": "MIT",
    "homepage": "https://backgrounderase.com",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "backgrounderase",
        "background-removal",
        "image"
    ],
    "author": {
        "name": "BackgroundErase",
        "email": "support@backgrounderase.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/BackgroundErase/no-code-integrations"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/BackgroundEraseApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/BackgroundErase/BackgroundErase.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.39.4",
        "prettier": "3.8.3",
        "release-it": "20.0.0",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "engines": {
        "node": ">=22"
    }
}
